---
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../data/projects.js';
const mainProjects = projects.filter(p => !p.journal && !p.hidden);
---

<Layout title="Projects" description="Explore Studio Kaku's portfolio of art framing, installation, curation and creative direction projects across Tokyo and Japan.">
  <!-- Header -->
  <section class="px-8 md:px-16 pt-24 pb-16">
    <h1 class="font-display uppercase leading-none" style="font-size: clamp(1.75rem, 4vw, 3.5rem);" data-en="Projects" data-ja="プロジェクト">
      Projects
    </h1>
  </section>

  <!-- Projects grid -->
  <section class="px-8 md:px-16 pb-24">
    <div class="grid grid-cols-2 md:grid-cols-3 gap-5 md:gap-7">
      {mainProjects.map((project, i) => {
        const featured = i % 5 === 0;
        return (
          <a
            href={`/projects/${project.slug}`}
            class={`group${featured ? ' col-span-2' : ''}`}
            data-fade
            style={`transition-delay: ${(i % 3) * 80}ms`}
          >
            <div class="overflow-hidden aspect-[3/2]">
              <img
                src={`/projects/${project.slug}/${encodeURIComponent(project.cover)}`}
                alt={project.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                loading="lazy"
              />
            </div>
            <div class="mt-3">
              <p class="font-display tracking-widest uppercase group-hover:opacity-40 transition-opacity" style="font-size: clamp(1rem, 1.5vw, 1.4rem);">{project.title}</p>
              {project.tagline && (
                <p class="text-xs text-brand-muted mt-1 group-hover:opacity-40 transition-opacity">{project.tagline}</p>
              )}
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- CTA -->
  <section class="px-8 md:px-16 py-20 border-t border-brand-border">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8">
      <p class="font-display uppercase leading-none" style="font-size: clamp(1.75rem, 4vw, 3.5rem);" data-en="Want to work<br />together?" data-ja="一緒に<br />取り組みませんか？">
        Want to work<br />together?
      </p>
      <a
        href="/contact"
        class="inline-block bg-brand-text text-brand-bg px-10 py-4 text-sm tracking-widest uppercase hover:opacity-80 transition-opacity flex-shrink-0"
        data-en="Get in Touch"
        data-ja="お問い合わせ"
      >
        Get in Touch
      </a>
    </div>
  </section>
</Layout>
