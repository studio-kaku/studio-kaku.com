---
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../data/projects.js';
---

<Layout title="Projects">
  <!-- Header -->
  <section class="px-8 md:px-12 pt-24 pb-12 border-b border-brand-border">
    <h1 class="font-display uppercase leading-none" style="font-size: clamp(3rem, 9vw, 11rem);">
      Projects
    </h1>
  </section>

  <!-- Projects grid -->
  <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-brand-border mt-px">
    {projects.map((project) => (
      <a href={`/projects/${project.slug}`} class="group bg-brand-bg overflow-hidden">
        <div class="overflow-hidden aspect-[4/3]">
          <img
            src={`/projects/${project.slug}/${encodeURIComponent(project.cover)}`}
            alt={project.title}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            loading="lazy"
          />
        </div>
        <div class="px-6 py-5 border-t border-brand-border">
          <p class="font-display uppercase text-lg tracking-wide">{project.title}</p>
        </div>
      </a>
    ))}
  </section>

  <!-- CTA -->
  <section class="px-8 md:px-12 py-20 border-t border-brand-border mt-px">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8">
      <p class="font-display uppercase leading-none" style="font-size: clamp(2rem, 4vw, 5rem);">
        Want to work<br />together?
      </p>
      <a
        href="/contact"
        class="inline-block bg-brand-text text-brand-bg px-10 py-4 text-sm tracking-widest uppercase hover:opacity-80 transition-opacity flex-shrink-0"
      >
        Get in Touch
      </a>
    </div>
  </section>
</Layout>
