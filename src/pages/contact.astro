---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact"
  description="Get in touch with Studio Kaku for framing, installation, art consultancy and creative direction enquiries."
>
  <!-- Page header -->
  <section class="max-w-5xl mx-auto px-6 pt-16 pb-12 border-b border-brand-border">
    <p class="text-brand-muted text-sm tracking-widest uppercase mb-4">Reach us</p>
    <h1 class="font-serif text-4xl">Contact</h1>
  </section>

  <section class="max-w-5xl mx-auto px-6 py-16 grid md:grid-cols-2 gap-16">
    <!-- Contact info -->
    <div>
      <h2 class="font-serif text-2xl mb-8">Let's talk</h2>
      <p class="text-brand-muted leading-relaxed mb-10">
        Whether you're looking to frame a single work, install a collection,
        build an art programme or commission something entirely new — we'd
        love to hear from you.
      </p>

      <div class="space-y-6 text-sm">
        <div>
          <p class="text-brand-muted tracking-widest uppercase text-xs mb-1">Email</p>
          <!-- Placeholder: update with real email address -->
          <a href="mailto:hello@studio-kaku.com" class="hover:opacity-70 transition-opacity underline underline-offset-4">
            hello@studio-kaku.com
          </a>
        </div>
        <div>
          <p class="text-brand-muted tracking-widest uppercase text-xs mb-1">Based in</p>
          <p>London, UK</p>
        </div>
        <div>
          <p class="text-brand-muted tracking-widest uppercase text-xs mb-1">Instagram</p>
          <!-- Placeholder: update with real handle -->
          <a href="#" class="hover:opacity-70 transition-opacity underline underline-offset-4">
            @studiokaku
          </a>
        </div>
      </div>
    </div>

    <!-- Simple enquiry form (static — wire up to a service like Formspree or Netlify Forms) -->
    <div>
      <h2 class="font-serif text-2xl mb-8">Enquiry form</h2>
      <form
        action="https://formspree.io/f/placeholder"
        method="POST"
        class="space-y-5"
      >
        <div>
          <label for="name" class="block text-xs tracking-widest uppercase text-brand-muted mb-2">
            Name
          </label>
          <input
            id="name"
            name="name"
            type="text"
            required
            class="w-full border border-brand-border bg-transparent px-4 py-3 text-sm focus:outline-none focus:border-brand-text transition-colors"
            placeholder="Your name"
          />
        </div>
        <div>
          <label for="email" class="block text-xs tracking-widest uppercase text-brand-muted mb-2">
            Email
          </label>
          <input
            id="email"
            name="email"
            type="email"
            required
            class="w-full border border-brand-border bg-transparent px-4 py-3 text-sm focus:outline-none focus:border-brand-text transition-colors"
            placeholder="your@email.com"
          />
        </div>
        <div>
          <label for="service" class="block text-xs tracking-widest uppercase text-brand-muted mb-2">
            Service
          </label>
          <select
            id="service"
            name="service"
            class="w-full border border-brand-border bg-brand-bg px-4 py-3 text-sm focus:outline-none focus:border-brand-text transition-colors"
          >
            <option value="">Select a service</option>
            <option value="framing">Framing &amp; Installation</option>
            <option value="care">Art Care</option>
            <option value="consultancy">Art Consultancy</option>
            <option value="direction">Creative Direction</option>
            <option value="curation">Curation</option>
            <option value="other">Other / Not sure</option>
          </select>
        </div>
        <div>
          <label for="message" class="block text-xs tracking-widest uppercase text-brand-muted mb-2">
            Message
          </label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            class="w-full border border-brand-border bg-transparent px-4 py-3 text-sm focus:outline-none focus:border-brand-text transition-colors resize-none"
            placeholder="Tell us about your project…"
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full bg-brand-text text-brand-bg py-3 text-sm tracking-wide hover:opacity-80 transition-opacity"
        >
          Send Enquiry
        </button>
      </form>
    </div>
  </section>
</Layout>
