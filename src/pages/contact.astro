---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact"
  description="Get in touch with Studio Kaku for framing, installation, art consultancy and creative direction enquiries."
>
  <!-- Page header -->
  <section class="px-8 md:px-12 pt-14 md:pt-20 pb-10 md:pb-16">
    <p class="text-brand-muted text-xs tracking-widest uppercase mb-8">Reach us</p>
    <h1 class="font-display uppercase leading-none" style="font-size: clamp(3rem, 9vw, 11rem);">Contact</h1>
  </section>

  <section class="px-8 md:px-12 py-14 md:py-24 border-t border-brand-border grid md:grid-cols-2 gap-14 md:gap-24">
    <!-- Contact info -->
    <div>
      <h2 class="font-serif text-4xl mb-10">Let's talk</h2>
      <p class="text-brand-muted leading-relaxed text-lg mb-16">
        Whether you're looking to frame a single work, install a collection,
        build an art programme or commission something entirely new — we'd
        love to hear from you.
      </p>

      <div class="space-y-10 text-sm">
        <div>
          <p class="text-brand-muted tracking-widest uppercase text-xs mb-3">Email</p>
          <a href="mailto:hello@studio-kaku.com" class="text-base hover:opacity-50 transition-opacity underline underline-offset-4">
            hello@studio-kaku.com
          </a>
        </div>
        <div>
          <p class="text-brand-muted tracking-widest uppercase text-xs mb-3">Based in</p>
          <p class="text-base">London, UK</p>
        </div>
        <div>
          <p class="text-brand-muted tracking-widest uppercase text-xs mb-3">Instagram</p>
          <a href="#" class="text-base hover:opacity-50 transition-opacity underline underline-offset-4">
            @studiokaku
          </a>
        </div>
      </div>
    </div>

    <!-- Enquiry form -->
    <div>
      <h2 class="font-serif text-4xl mb-10">Enquiry form</h2>
      <form
        action="https://formspree.io/f/placeholder"
        method="POST"
        class="space-y-7"
      >
        <div>
          <label for="name" class="block text-xs tracking-widest uppercase text-brand-muted mb-3">
            Name
          </label>
          <input
            id="name"
            name="name"
            type="text"
            required
            class="w-full border-b border-brand-border bg-transparent pb-3 text-sm focus:outline-none focus:border-brand-text transition-colors"
            placeholder="Your name"
          />
        </div>
        <div>
          <label for="email" class="block text-xs tracking-widest uppercase text-brand-muted mb-3">
            Email
          </label>
          <input
            id="email"
            name="email"
            type="email"
            required
            class="w-full border-b border-brand-border bg-transparent pb-3 text-sm focus:outline-none focus:border-brand-text transition-colors"
            placeholder="your@email.com"
          />
        </div>
        <div>
          <label for="service" class="block text-xs tracking-widest uppercase text-brand-muted mb-3">
            Service
          </label>
          <select
            id="service"
            name="service"
            class="w-full border-b border-brand-border bg-transparent pb-3 text-sm focus:outline-none focus:border-brand-text transition-colors"
          >
            <option value="">Select a service</option>
            <option value="framing">Framing &amp; Installation</option>
            <option value="care">Art Care</option>
            <option value="consultancy">Art Consultancy</option>
            <option value="direction">Creative Direction</option>
            <option value="curation">Curation</option>
            <option value="other">Other / Not sure</option>
          </select>
        </div>
        <div>
          <label for="message" class="block text-xs tracking-widest uppercase text-brand-muted mb-3">
            Message
          </label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            class="w-full border-b border-brand-border bg-transparent pb-3 text-sm focus:outline-none focus:border-brand-text transition-colors resize-none"
            placeholder="Tell us about your project…"
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full bg-brand-text text-brand-bg py-4 text-sm tracking-widest uppercase hover:opacity-80 transition-opacity mt-4"
        >
          Send Enquiry
        </button>
      </form>
    </div>
  </section>
</Layout>
