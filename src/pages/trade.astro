---
import Layout from '../layouts/Layout.astro';
import PasswordGate from '../components/PasswordGate.astro';
---

<Layout title="Trade partnership - Studio Kaku" description="Studio Kaku works with interior designers, real estate developers, and property companies - Japanese art and craft sourced and installed for your projects." noindex={true}>

  <PasswordGate password="kaku-trade" />

  <!-- Hero -->
  <section class="min-h-[90vh] grid md:grid-cols-2 bg-brand-text">
    <div class="flex flex-col justify-between px-8 md:px-16 pt-12 pb-20 md:pt-14 md:pb-28">
      <p class="text-[10px] tracking-[0.25em] uppercase text-brand-accent" data-en="For trade partners - private document" data-ja="トレードパートナー向け - 非公開資料">For trade partners - private document</p>
      <div>
        <h1 class="font-display uppercase leading-[1.08] text-brand-bg" style="font-size: clamp(2.5rem, 5vw, 4.5rem);" data-fade-text data-en="A creative partner<br />for your <em class=&quot;not-italic text-brand-accent&quot;>projects</em>" data-ja="あなたのプロジェクトの<br /><em class=&quot;not-italic text-brand-accent&quot;>クリエイティブパートナー</em>">
          A creative partner<br />for your <em class="not-italic text-brand-accent">projects</em>
        </h1>
        <p class="text-brand-bg/45 text-sm leading-relaxed max-w-sm mt-7" data-fade-text style="transition-delay:80ms" data-en="Studio Kaku works with interior designers, developers, and property companies as a specialist sourcing and curation partner - bringing Japanese art and craft into projects that benefit from it." data-ja="Studio Kakuはインテリアデザイナー、デベロッパー、不動産会社と、専門的な調達・キュレーションパートナーとして協働します——日本のアートと工芸を、価値が生まれるプロジェクトにもたらします。">
          Studio Kaku works with interior designers, developers, and property companies as a specialist sourcing and curation partner - bringing Japanese art and craft into projects that benefit from it.
        </p>
      </div>
      <p class="text-brand-bg/25 text-[11px] tracking-wide" data-en="Studio Kaku · Trade partnerships" data-ja="Studio Kaku · トレードパートナーシップ">Studio Kaku · Trade partnerships</p>
    </div>
    <div class="border-t md:border-t-0 md:border-l border-brand-bg/[0.08] px-8 md:px-16 py-20 md:py-28 flex flex-col justify-center gap-10">
      {[
        { num: '10+', label: 'Japanese artists available as prints, editions, originals, and bespoke commissions.', labelJa: 'プリント、エディション、オリジナル、ビスポークコミッションとして提供できる日本人アーティスト。' },
        { num: '3', label: 'Partner disciplines under one roof: art curation, Japanese craft, and interior design.', labelJa: 'ひとつの屋根の下にある3つの専門領域：アートキュレーション、日本工芸、インテリアデザイン。' },
        { num: '1', label: 'Point of contact. Everything coordinated by Studio Kaku - nothing falls between the gaps.', labelJa: '窓口はひとつ。すべてStudio Kakuがコーディネートします——何も取りこぼしません。' },
      ].map((stat, i) => (
        <div class="border-t border-brand-bg/10 pt-6" data-fade style={`transition-delay:${i * 80}ms`}>
          <p class="font-display text-brand-bg leading-none" style="font-size: clamp(2.5rem, 5vw, 3rem);">{stat.num}</p>
          <p class="text-brand-bg/40 text-xs mt-2 tracking-wide" data-en={stat.label} data-ja={stat.labelJa}>{stat.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- What the partnership offers -->
  <section class="bg-brand-bg px-8 md:px-16 py-20 md:py-28 border-t border-brand-border">
    <p class="text-[10px] tracking-[0.25em] uppercase text-brand-accent mb-5 flex items-center gap-4">
      <span data-en="What you get" data-ja="パートナーシップの内容">What you get</span>
      <span class="block h-px w-12 bg-brand-accent/40"></span>
    </p>
    <h2 class="font-display uppercase leading-[1.1] mb-5" style="font-size: clamp(2rem, 4vw, 3.25rem);" data-en="What working with<br />Studio Kaku gives you" data-ja="Studio Kakuとの協働が<br />もたらすもの">
      What working with<br />Studio Kaku gives you
    </h2>
    <p class="text-brand-muted text-sm leading-relaxed max-w-lg mb-16" data-en="We are not a gallery or an online shop. We are a working studio with direct relationships with artists and makers - and a track record of getting work specified, sourced, and installed on time." data-ja="私たちはギャラリーでもオンラインショップでもありません。アーティストや作家と直接関係を持ち、仕事を仕様に落とし込み、調達し、期限内に設置してきた実績のある、現場で動くスタジオです。">
      We are not a gallery or an online shop. We are a working studio with direct relationships with artists and makers - and a track record of getting work specified, sourced, and installed on time.
    </p>
    <div class="grid md:grid-cols-3 gap-px bg-brand-border">
      {[
        {
          num: '01',
          title: 'Access to artists and makers',
          titleJa: 'アーティスト・作家へのアクセス',
          body: 'Ten Japanese artists available across a range of media and price points - prints, editions, originals, and bespoke commissions. We can also source beyond our direct roster when a project calls for something specific.',
          bodyJa: '様々なメディアと価格帯にわたる10名の日本人アーティスト——プリント、エディション、オリジナル、ビスポークコミッション。プロジェクトが特定のものを必要とする場合は、直接のロースター外からも調達できます。',
          note: 'Works and commissions available to your spec',
          noteJa: 'お客様の仕様に合わせた作品とコミッション',
        },
        {
          num: '02',
          title: 'Framing, sourcing, and installation',
          titleJa: '額装、調達、設置',
          body: 'We handle the full logistics chain - framing, shipping, customs if needed, and installation. For designers who want the creative credit without the operational burden, we work quietly in the background.',
          bodyJa: '額装、輸送、必要に応じた通関、設置まで——物流チェーン全体を担います。クリエイティブのクレジットを持ちながら運営の負担を避けたいデザイナーのために、私たちは静かに裏方に回ります。',
          note: 'End-to-end logistics managed',
          noteJa: 'エンドツーエンドの物流を管理',
        },
        {
          num: '03',
          title: 'A specialist voice on your project',
          titleJa: 'プロジェクトへの専門的な視点',
          body: 'Sometimes a project needs a specialist who can speak to art, craft, and cultural context - not just supply pieces. We can join your client conversations, attend site visits, or contribute to a brief as a named collaborator.',
          bodyJa: 'プロジェクトには、単に作品を供給するだけでなく、アート、工芸、文化的文脈について語れる専門家が必要なことがあります。私たちはクライアントとの会話に参加し、現場視察に同行し、名前のあるコラボレーターとしてブリーフに貢献できます。',
          note: 'Named collaborator available if useful',
          noteJa: '必要に応じて名前のあるコラボレーターとして',
        },
      ].map((item, i) => (
        <div class="bg-brand-bg p-10 md:p-12" data-fade style={`transition-delay:${i * 80}ms`}>
          <span class="font-display text-[11px] tracking-[0.2em] mb-5 block text-brand-accent">{item.num}</span>
          <h4 class="font-display uppercase mb-4" style="font-size: 1.2rem;" data-en={item.title} data-ja={item.titleJa}>{item.title}</h4>
          <p class="text-brand-muted text-sm leading-relaxed mb-5" data-en={item.body} data-ja={item.bodyJa}>{item.body}</p>
          <p class="text-brand-accent text-xs tracking-wide" data-en={item.note} data-ja={item.noteJa}>{item.note}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Previous clients -->
  <section class="px-8 md:px-16 py-20 md:py-28 border-t border-brand-border bg-brand-border/20">
    <p class="text-[10px] tracking-[0.25em] uppercase text-brand-accent mb-5 flex items-center gap-4">
      <span data-en="Previous work" data-ja="これまでの実績">Previous work</span>
      <span class="block h-px w-12 bg-brand-accent/40"></span>
    </p>
    <h2 class="font-display uppercase leading-[1.1] mb-5" style="font-size: clamp(2rem, 4vw, 3.25rem);" data-en="Clients and partners<br />we've worked with" data-ja="これまでに携わった<br />クライアントとパートナー">
      Clients and partners<br />we've worked with
    </h2>
    <p class="text-brand-muted text-sm leading-relaxed max-w-lg mb-16" data-en="Across hospitality, real estate, retail, and the arts - Studio Kaku has sourced, placed, and installed for organisations that understand what considered spaces do." data-ja="ホスピタリティ、不動産、小売、芸術の分野で——Studio Kakuは、空間の力を理解する組織のために調達・配置・設置を行ってきました。">
      Across hospitality, real estate, retail, and the arts - Studio Kaku has sourced, placed, and installed for organisations that understand what considered spaces do.
    </p>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-brand-border">
      {[
        { img: '/images/logos/soho-house.png', name: 'Soho House' },
        { img: '/images/logos/tokyo-american-club.webp', name: 'Tokyo American Club' },
        { img: '/images/logos/mitsui-fudosan.png', name: 'Mitsui Fudosan' },
        { img: '/images/logos/isetan.svg', name: 'Isetan' },
        { img: '/images/logos/courtyard-hiroo.png', name: 'Courtyard by Marriott Hiroo' },
        { img: '/images/logos/haneda.png', name: 'Haneda Airport' },
        { img: '/images/logos/ceysson-benetiere.jpg', name: 'Ceysson & Bénétière' },
        { img: '/images/logos/gallery-ether.png', name: 'Gallery Ether' },
        { img: '/images/logos/somsoc-gallery.png', name: 'Somsoc Gallery' },
        { img: '/images/logos/bluebell.jpg', name: 'Bluebell' },
        { img: '/images/logos/ultra-super-new.png', name: 'Ultra Super New' },
      ].map((client, i) => (
        <div class="bg-brand-bg flex items-center justify-center p-8 md:p-10 aspect-[3/2]" data-fade style={`transition-delay:${(i % 4) * 60}ms`}>
          <img src={client.img} alt={client.name} class="max-h-8 max-w-[120px] object-contain opacity-50 hover:opacity-80 transition-opacity" />
        </div>
      ))}
    </div>
  </section>

  <!-- The team -->
  <section class="bg-brand-text px-8 md:px-16 py-20 md:py-28">
    <p class="text-[10px] tracking-[0.25em] uppercase text-brand-accent mb-5 flex items-center gap-4">
      <span data-en="The team" data-ja="チーム">The team</span>
      <span class="block h-px w-12 bg-brand-accent/30"></span>
    </p>
    <h2 class="font-display uppercase leading-[1.1] text-brand-bg mb-5" style="font-size: clamp(2rem, 4vw, 3.25rem);" data-en="Who you'll be<br />working with" data-ja="一緒に仕事をする<br />人たち">
      Who you'll be<br />working with
    </h2>
    <p class="text-brand-bg/50 text-sm leading-relaxed max-w-lg mb-16" data-en="Studio Kaku is led by Eleanor and Yuki. Between them: gallery experience in London and Tokyo, deep relationships with Japanese artists and makers, and a practical understanding of how large-scale art installation actually works." data-ja="Studio KakuはEleanorとYukiが率います。ロンドンと東京でのギャラリー経験、日本のアーティストや作家との深い関係、そして大規模なアート設置が実際にどのように機能するかの実践的な理解——それが二人の間にあるものです。">
      Studio Kaku is led by Eleanor and Yuki. Between them: gallery experience in London and Tokyo, deep relationships with Japanese artists and makers, and a practical understanding of how large-scale art installation actually works.
    </p>
    <div class="grid md:grid-cols-2 gap-px bg-brand-bg/10">
      {[
        {
          img: '/images/team-eleanor.jpg',
          name: 'Eleanor',
          role: 'Co-founder · Creative direction',
          roleJa: '共同創業者 · クリエイティブディレクション',
          body: 'Gallery background in London. Led curation and client relationships at Studio Kaku since founding - focused on the artists, the brief, and getting projects over the line.',
          bodyJa: 'ロンドンでのギャラリー経験を持つ。創業以来Studio Kakuのキュレーションとクライアントリレーションを担当——アーティスト、ブリーフ、そしてプロジェクトを完成させることに注力。',
        },
        {
          img: '/images/team-yuki.jpg',
          name: 'Yuki',
          role: 'Co-founder · Japan relations',
          roleJa: '共同創業者 · 日本リレーションズ',
          body: 'Based in Tokyo. Manages all artist relationships, sourcing logistics, and the network of Japanese makers Studio Kaku works with. The practical intelligence behind every project.',
          bodyJa: '東京在住。すべてのアーティストとのリレーション、調達物流、Studio Kakuが協働する日本の作家ネットワークを管理。すべてのプロジェクトを支える実務的知性。',
        },
      ].map((person, i) => (
        <div class="flex flex-col md:flex-row gap-0" data-fade style={`transition-delay:${i * 80}ms`}>
          <div class="md:w-1/3 aspect-square md:aspect-auto overflow-hidden flex-shrink-0">
            <img src={person.img} alt={person.name} class="w-full h-full object-cover" />
          </div>
          <div class="p-10 md:p-12 flex flex-col justify-center">
            <p class="text-[10px] tracking-[0.18em] uppercase text-brand-accent mb-2" data-en={person.role} data-ja={person.roleJa}>{person.role}</p>
            <h3 class="font-display uppercase text-brand-bg mb-4" style="font-size: 1.4rem;">{person.name}</h3>
            <p class="text-brand-bg/45 text-sm leading-relaxed" data-en={person.body} data-ja={person.bodyJa}>{person.body}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- How to work together -->
  <section class="px-8 md:px-16 pt-16 pb-10 md:pt-24 md:pb-16 border-t border-brand-border">
    <p class="text-[10px] tracking-[0.25em] uppercase text-brand-accent mb-8 flex items-center gap-4">
      <span data-en="How to work together" data-ja="協働の方法">How to work together</span>
      <span class="block h-px w-12 bg-brand-accent/40"></span>
    </p>
    <h2 class="font-display uppercase leading-[1.1] mb-8" style="font-size: clamp(2rem, 4vw, 3.25rem);"
      data-en="Three ways we<br />can work with you."
      data-ja="三つの協働モデル。"
    >
      Three ways we<br />can work with you.
    </h2>
    <p class="text-brand-muted text-sm leading-relaxed max-w-lg mb-14"
      data-en="Every trade relationship is different. Some partners want a specialist supplier. Others want a collaborator at the table. We are comfortable with both - and with anything between."
      data-ja="すべてのトレード関係は異なります。専門的なサプライヤーを求めるパートナーもいれば、テーブルでのコラボレーターを求めるパートナーもいます。どちらにも、そしてその間のあらゆる関係にも対応できます。"
    >
      Every trade relationship is different. Some partners want a specialist supplier. Others want a collaborator at the table. We are comfortable with both - and with anything between.
    </p>
    <div class="grid md:grid-cols-3 gap-px bg-brand-border">
      <!-- Sourcing -->
      <div class="bg-brand-bg p-10 md:p-12" data-fade style="transition-delay:0ms">
        <h3 class="font-display uppercase leading-[1.15] mb-2" style="font-size: clamp(1rem, 1.8vw, 1.35rem);"
          data-en="Specialist<br />Sourcing"
          data-ja="専門的な<br />調達"
        >Specialist<br />Sourcing</h3>
        <p class="text-brand-accent text-[11px] tracking-wide mb-6"
          data-en="We supply. You specify."
          data-ja="私たちが供給する。あなたが仕様を決める。"
        >We supply. You specify.</p>
        <p class="text-brand-muted text-sm leading-relaxed mb-8"
          data-en="You tell us what the project needs - scale, medium, tone, budget. We source from our network of Japanese artists and makers and deliver to your spec. You maintain the client relationship and take the creative credit."
          data-ja="プロジェクトが必要とするものをお伝えください——スケール、メディア、トーン、予算。私たちは日本のアーティストと作家のネットワークから調達し、仕様に合わせてお届けします。クライアントとのリレーションとクリエイティブのクレジットはあなたのものです。"
        >
          You tell us what the project needs - scale, medium, tone, budget. We source from our network of Japanese artists and makers and deliver to your spec. You maintain the client relationship and take the creative credit.
        </p>
        <ul class="space-y-0 border-t border-brand-border pt-5">
          {[
            ['Works sourced to your brief', 'あなたのブリーフに合わせた作品調達'],
            ['Framing and finishing managed', '額装と仕上げを管理'],
            ['Shipping and installation arranged', '輸送と設置を手配'],
            ['Trade pricing available', 'トレード価格あり'],
          ].map(([en, ja]) => (
            <li class="text-[11px] text-brand-muted py-2.5 border-b border-brand-border flex gap-2" data-en={en} data-ja={ja}>
              <span class="text-brand-accent/50 flex-shrink-0">-</span>
              {en}
            </li>
          ))}
        </ul>
      </div>
      <!-- Collaboration -->
      <div class="bg-brand-bg p-10 md:p-12" data-fade style="transition-delay:80ms">
        <h3 class="font-display uppercase leading-[1.15] mb-2" style="font-size: clamp(1rem, 1.8vw, 1.35rem);"
          data-en="Project<br />Collaboration"
          data-ja="プロジェクト<br />コラボレーション"
        >Project<br />Collaboration</h3>
        <p class="text-brand-accent text-[11px] tracking-wide mb-6"
          data-en="We join the team for the duration."
          data-ja="期間中、チームの一員として参加する。"
        >We join the team for the duration.</p>
        <p class="text-brand-muted text-sm leading-relaxed mb-8"
          data-en="For projects where art and cultural context are part of the brief from the start. Studio Kaku joins as a specialist collaborator - attending client meetings, contributing to the creative direction, and handling all sourcing and installation."
          data-ja="アートと文化的文脈が最初からブリーフの一部となるプロジェクトのために。Studio Kakuは専門的なコラボレーターとして参加——クライアントミーティングに出席し、クリエイティブディレクションに貢献し、すべての調達と設置を担います。"
        >
          For projects where art and cultural context are part of the brief from the start. Studio Kaku joins as a specialist collaborator - attending client meetings, contributing to the creative direction, and handling all sourcing and installation.
        </p>
        <ul class="space-y-0 border-t border-brand-border pt-5">
          {[
            ['Creative consultation from the start', '最初からのクリエイティブコンサルテーション'],
            ['Client-facing if useful', '必要に応じてクライアント対応'],
            ['Full sourcing and curation', '完全な調達とキュレーション'],
            ['Framing, installation, handover', '額装、設置、引き渡し'],
            ['Named collaborator credit available', '名前のあるコラボレーターとしてのクレジット'],
          ].map(([en, ja]) => (
            <li class="text-[11px] text-brand-muted py-2.5 border-b border-brand-border flex gap-2" data-en={en} data-ja={ja}>
              <span class="text-brand-accent/50 flex-shrink-0">-</span>
              {en}
            </li>
          ))}
        </ul>
      </div>
      <!-- Retainer -->
      <div class="bg-brand-text p-10 md:p-12" data-fade style="transition-delay:160ms">
        <h3 class="font-display uppercase text-brand-bg leading-[1.15] mb-2" style="font-size: clamp(1rem, 1.8vw, 1.35rem);"
          data-en="Preferred<br />Partner"
          data-ja="優先的な<br />パートナー"
        >Preferred<br />Partner</h3>
        <p class="text-brand-accent text-[11px] tracking-wide mb-6"
          data-en="A standing relationship for ongoing work."
          data-ja="継続的な仕事のための、長期的な関係。"
        >A standing relationship for ongoing work.</p>
        <p class="font-display leading-none text-brand-bg mb-1" style="font-size: clamp(1.6rem, 2.5vw, 2rem);">By arrangement</p>
        <p class="text-brand-bg/40 text-xs mb-6" data-en="retainer or per-project basis" data-ja="リテイナーまたはプロジェクト単位">retainer or per-project basis</p>
        <p class="text-brand-bg/50 text-sm leading-relaxed mb-8"
          data-en="For studios and developers with a regular flow of projects that benefit from Japanese art and craft. First-look access to new works, trade pricing, and Studio Kaku as a trusted specialist on call."
          data-ja="日本のアートと工芸が価値をもたらす案件を定期的に手がけるスタジオやデベロッパーのために。新作への先行アクセス、トレード価格、そして信頼できる専門家としてのStudio Kaくを。"
        >
          For studios and developers with a regular flow of projects that benefit from Japanese art and craft. First-look access to new works, trade pricing, and Studio Kaku as a trusted specialist on call.
        </p>
        <ul class="space-y-0 border-t border-brand-bg/10 pt-5">
          {[
            ['First-look access to new works', '新作への先行アクセス'],
            ['Trade pricing on all sourcing', '全調達へのトレード価格'],
            ['Priority turnaround on briefs', 'ブリーフへの優先対応'],
            ['Ongoing creative consultation', '継続的なクリエイティブコンサルテーション'],
            ['Studio Kaku on retainer', 'リテイナーとしてのStudio Kaku'],
          ].map(([en, ja]) => (
            <li class="text-[11px] text-brand-bg/40 py-2.5 border-b border-brand-bg/[0.08] flex gap-2" data-en={en} data-ja={ja}>
              <span class="text-brand-accent/50 flex-shrink-0">-</span>
              {en}
            </li>
          ))}
        </ul>
      </div>
    </div>
    <div class="mt-12 text-center">
      <p class="text-brand-muted text-sm mb-4"
        data-en="Have a project in mind? We're happy to have an initial conversation."
        data-ja="お考えのプロジェクトがありますか？まずはお気軽にご相談ください。"
      >Have a project in mind? We're happy to have an initial conversation.</p>
      <a href="mailto:hello@studiokaku.com" class="text-brand-text text-[11px] tracking-[0.2em] uppercase underline underline-offset-4 hover:text-brand-accent transition-colors"
        data-en="Get in touch →"
        data-ja="お問い合わせ →"
      >Get in touch →</a>
    </div>
  </section>

  <!-- The artists (condensed) -->
  <section class="px-8 md:px-16 pt-16 pb-10 md:pt-24 md:pb-16 border-t border-brand-border bg-brand-border/20">
    <p class="text-[10px] tracking-[0.25em] uppercase text-brand-accent mb-8 flex items-center gap-4">
      <span data-en="The roster" data-ja="アーティストラインナップ">The roster</span>
      <span class="block h-px w-12 bg-brand-accent/40"></span>
    </p>
    <div class="flex flex-col md:flex-row md:items-end gap-6 md:gap-24 mb-16">
      <h2 class="font-display uppercase leading-[1.1] shrink-0" style="font-size: clamp(2rem, 4vw, 3.25rem);"
        data-en="Japanese artists<br />available to specify"
        data-ja="仕様として指定できる<br />日本のアーティスト"
      >
