---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects.js';
const featuredProjects = projects.slice(0, 6);
---

<Layout title="Home">
  <!-- Hero -->
  <section class="px-8 md:px-12 pt-24 pb-12">
    <h1
      class="font-display uppercase leading-[0.9] mb-14"
      style="font-size: clamp(3rem, 9vw, 11rem);"
    >
      Where art<br />finds its place.
    </h1>
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 border-t border-brand-border pt-8">
      <p class="text-brand-muted text-base leading-relaxed max-w-md">
        Studio Kaku brings together specialist expertise in framing, installation
        and art care alongside art consultancy, creative direction and curation.
        We help collectors, galleries and organisations live and work with art
        at its best.
      </p>
      <a
        href="/services"
        class="inline-block border border-brand-text px-7 py-3 text-sm tracking-widest uppercase hover:bg-brand-text hover:text-brand-bg transition-colors flex-shrink-0"
      >
        Our Services
      </a>
    </div>
  </section>

  <!-- Projects preview -->
  <section class="px-8 md:px-12 py-20 border-t border-brand-border mt-1">
    <div class="flex items-end justify-between mb-10">
      <h2 class="font-display uppercase leading-none" style="font-size: clamp(2rem, 5vw, 5rem);">Projects</h2>
      <a
        href="/projects"
        class="text-sm tracking-widest uppercase underline underline-offset-4 hover:opacity-50 transition-opacity flex-shrink-0"
      >
        View all
      </a>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-1">
      {featuredProjects.map((project) => (
        <a href={`/projects/${project.slug}`} class="group overflow-hidden">
          <div class="overflow-hidden aspect-[4/3]">
            <img
              src={`/projects/${project.slug}/${encodeURIComponent(project.cover)}`}
              alt={project.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              loading="lazy"
            />
          </div>
          <p class="mt-3 text-sm tracking-wide uppercase group-hover:opacity-50 transition-opacity">
            {project.title}
          </p>
          {project.tagline && (
            <p class="text-xs text-brand-muted mt-1 group-hover:opacity-50 transition-opacity">
              {project.tagline}
            </p>
          )}
        </a>
      ))}
    </div>
  </section>

  <!-- Two services -->
  <section class="px-8 md:px-12 py-28 grid md:grid-cols-2 gap-20 border-t border-brand-border mt-1">
    <div>
      <p class="text-brand-muted text-xs tracking-widest uppercase mb-8">01</p>
      <h2 class="font-serif text-4xl md:text-5xl mb-6">Framing, Installation &amp; Art Care</h2>
      <p class="text-brand-muted leading-relaxed mb-8">
        Expert framing and professional installation for works of all scales,
        alongside guidance on how to live with and look after your art for
        generations to come.
      </p>
      <a
        href="/services#framing"
        class="text-sm tracking-wide underline underline-offset-4 hover:opacity-50 transition-opacity"
      >
        Learn more
      </a>
    </div>
    <div>
      <p class="text-brand-muted text-xs tracking-widest uppercase mb-8">02</p>
      <h2 class="font-serif text-4xl md:text-5xl mb-6">Art Consultancy &amp; Creative Direction</h2>
      <p class="text-brand-muted leading-relaxed mb-8">
        Strategic art consultancy, curatorial vision and creative direction for
        private collectors, corporate clients and cultural institutions seeking
        a distinctive voice.
      </p>
      <a
        href="/services#consultancy"
        class="text-sm tracking-wide underline underline-offset-4 hover:opacity-50 transition-opacity"
      >
        Learn more
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="px-8 md:px-12 py-28 border-t border-brand-border">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-10">
      <p class="font-display uppercase leading-none" style="font-size: clamp(2.5rem, 5vw, 6rem);">
        Ready to work<br />together?
      </p>
      <a
        href="/contact"
        class="inline-block bg-brand-text text-brand-bg px-10 py-4 text-sm tracking-widest uppercase hover:opacity-80 transition-opacity flex-shrink-0"
      >
        Get in Touch
      </a>
    </div>
  </section>
</Layout>
