---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <!-- Hero -->
  <section class="max-w-7xl mx-auto px-8 pt-24 pb-16">
    <h1 class="font-serif text-6xl md:text-8xl lg:text-9xl leading-none mb-12 max-w-5xl">
      Where art finds its place.
    </h1>
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 max-w-4xl">
      <p class="text-brand-muted text-lg leading-relaxed max-w-md">
        Studio Kaku brings together specialist expertise in framing, installation
        and art care alongside art consultancy, creative direction and curation.
        We help collectors, galleries and organisations live and work with art
        at its best.
      </p>
      <a
        href="/services"
        class="inline-block border border-brand-text px-6 py-3 text-sm tracking-wide hover:bg-brand-text hover:text-brand-bg transition-colors flex-shrink-0"
      >
        Our Services
      </a>
    </div>
  </section>

  <!-- Photo showcase -->
  <section class="max-w-7xl mx-auto px-8 pb-4">
    <div class="grid grid-cols-2 md:grid-cols-3 gap-2">
      <img src="/images/framing-art-care.jpg" alt="Art framing and care" class="w-full aspect-[3/4] object-cover" />
      <img src="/images/installation-gallery.jpg" alt="Gallery installation" class="w-full aspect-[3/4] object-cover" />
      <div class="hidden md:flex flex-col gap-2">
        <img src="/images/framing-example.jpg" alt="Bespoke framed artwork" class="w-full flex-1 object-cover" />
        <img src="/images/consultancy-gallery.jpg" alt="Art consultancy" class="w-full flex-1 object-cover" />
      </div>
    </div>
  </section>

  <!-- Two services -->
  <section class="max-w-7xl mx-auto px-8 py-24 grid md:grid-cols-2 gap-16 border-t border-brand-border mt-16">
    <div>
      <p class="text-brand-muted text-xs tracking-widest uppercase mb-6">01</p>
      <h2 class="font-serif text-3xl mb-5">Framing, Installation &amp; Art Care</h2>
      <p class="text-brand-muted leading-relaxed mb-6">
        Expert framing and professional installation for works of all scales,
        alongside guidance on how to live with and look after your art for
        generations to come.
      </p>
      <a href="/services#framing" class="text-sm underline underline-offset-4 hover:opacity-70 transition-opacity">
        Learn more
      </a>
    </div>
    <div>
      <p class="text-brand-muted text-xs tracking-widest uppercase mb-6">02</p>
      <h2 class="font-serif text-3xl mb-5">Art Consultancy &amp; Creative Direction</h2>
      <p class="text-brand-muted leading-relaxed mb-6">
        Strategic art consultancy, curatorial vision and creative direction for
        private collectors, corporate clients and cultural institutions seeking
        a distinctive voice.
      </p>
      <a href="/services#consultancy" class="text-sm underline underline-offset-4 hover:opacity-70 transition-opacity">
        Learn more
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-7xl mx-auto px-8 py-20 border-t border-brand-border">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8">
      <p class="font-serif text-4xl md:text-5xl">Ready to work together?</p>
      <a
        href="/contact"
        class="inline-block bg-brand-text text-brand-bg px-8 py-4 text-sm tracking-wide hover:opacity-80 transition-opacity flex-shrink-0"
      >
        Get in Touch
      </a>
    </div>
  </section>
</Layout>
