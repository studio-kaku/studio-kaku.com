---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects.js';
const featuredProjects = projects.filter(p => !p.journal && p.slug !== 'tcs-2025').slice(0, 5);
const journalEntries = projects.filter(p => p.journal).slice(0, 8);
---

<Layout title="Home">
  <!-- Hero -->
  <section class="px-8 md:px-12 pt-10 md:pt-16 pb-6 md:pb-8">
    <h1
      class="font-display uppercase leading-[0.9] mb-8"
      style="font-size: clamp(2rem, 5vw, 5rem);"
    >
      Where art<br />finds its place.
    </h1>
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 border-t border-brand-border pt-8">
      <p class="text-brand-muted text-base leading-relaxed max-w-md">
        Studio Kaku brings together specialist expertise in framing, installation
        and art care alongside art consultancy, creative direction and curation.
        We help collectors, galleries and organisations live and work with art
        at its best.
      </p>
      <a
        href="/services"
        class="inline-block border border-brand-text px-7 py-3 text-sm tracking-widest uppercase hover:bg-brand-text hover:text-brand-bg transition-colors flex-shrink-0"
      >
        Our Services
      </a>
    </div>
  </section>

  <!-- Journal carousel -->
  <section class="py-8 md:py-12 border-t border-brand-border mt-1">
    <div class="px-8 md:px-12 flex items-end justify-between mb-10">
      <h2 class="font-display uppercase leading-none" style="font-size: clamp(2rem, 5vw, 5rem);">Journal</h2>
      <a
        href="/journal"
        class="text-sm tracking-widest uppercase underline underline-offset-4 hover:opacity-50 transition-opacity flex-shrink-0"
      >
        View all
      </a>
    </div>
    <!-- Draggable carousel -->
    <div
      id="journal-carousel"
      class="flex gap-5 overflow-x-auto px-8 md:px-12 pb-4 cursor-grab select-none"
      style="scrollbar-width: none; -ms-overflow-style: none;"
    >
      {journalEntries.map((entry) => (
        <a
          href={`/projects/${entry.slug}`}
          class="group flex-none w-72 md:w-80"
          draggable="false"
        >
          <div class="overflow-hidden aspect-[3/4] bg-brand-border mb-4">
            <img
              src={`/projects/${entry.slug}/${encodeURIComponent(entry.cover)}`}
              alt={entry.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 pointer-events-none"
              loading="lazy"
              draggable="false"
            />
          </div>
          <p class="text-xs text-brand-muted tracking-widest uppercase mb-1">{entry.year}</p>
          <p class="font-display uppercase leading-tight text-lg group-hover:opacity-50 transition-opacity">{entry.title}</p>
          <p class="text-xs text-brand-muted mt-1">{entry.tagline}</p>
        </a>
      ))}
    </div>
  </section>

  <script>
    const carousel = document.getElementById('journal-carousel');
    if (carousel) {
      let isDown = false;
      let startX = 0;
      let scrollLeft = 0;
      let moved = false;

      carousel.addEventListener('mousedown', (e) => {
        isDown = true;
        moved = false;
        startX = e.pageX - carousel.offsetLeft;
        scrollLeft = carousel.scrollLeft;
        carousel.style.cursor = 'grabbing';
      });
      carousel.addEventListener('mouseleave', () => { isDown = false; carousel.style.cursor = 'grab'; });
      carousel.addEventListener('mouseup', () => { isDown = false; carousel.style.cursor = 'grab'; });
      carousel.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - carousel.offsetLeft;
        const walk = (x - startX) * 1.5;
        if (Math.abs(walk) > 4) moved = true;
        carousel.scrollLeft = scrollLeft - walk;
      });
      // Single delegated listener prevents navigation after a drag
      carousel.addEventListener('click', (e) => { if (moved) e.preventDefault(); }, true);
    }
  </script>

  <!-- Projects preview -->
  <section class="px-8 md:px-12 py-12 md:py-20 border-t border-brand-border mt-1">
    <div class="flex items-end justify-between mb-10">
      <h2 class="font-display uppercase leading-none" style="font-size: clamp(2rem, 5vw, 5rem);">Projects</h2>
      <a
        href="/projects"
        class="text-sm tracking-widest uppercase underline underline-offset-4 hover:opacity-50 transition-opacity flex-shrink-0"
      >
        View all
      </a>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-5 md:gap-7">
      {featuredProjects.map((project, i) => {
        const featured = i === 0;
        return (
          <a href={`/projects/${project.slug}`} class={`group${featured ? ' col-span-2' : ''}`} data-fade style={`transition-delay: ${(i % 3) * 80}ms`}>
            <div class="overflow-hidden aspect-[3/2]">
              <img
                src={`/projects/${project.slug}/${encodeURIComponent(project.cover)}`}
                alt={project.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                loading="lazy"
              />
            </div>
            <div class="mt-3">
              <p class="text-sm tracking-widest uppercase group-hover:opacity-40 transition-opacity">{project.title}</p>
              {project.tagline && (
                <p class="text-xs text-brand-muted mt-1 group-hover:opacity-40 transition-opacity">{project.tagline}</p>
              )}
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Services list -->
  <section class="border-t border-brand-border mt-1">
    <div class="px-8 md:px-12 pt-16 md:pt-24 pb-4">
      <h2 class="font-display uppercase leading-none" style="font-size: clamp(2rem, 5vw, 5rem);">Services</h2>
    </div>
    {[
      {
        num: '01',
        title: 'Framing',
        description: 'Expert framing for works of all scales, using archival materials and bespoke mouldings suited to each piece.',
        href: '/services#framing',
        img: '/images/services/framing.jpg',
      },
      {
        num: '02',
        title: 'Shipment & Installation',
        description: 'Professional handling, transport and installation for private collectors, galleries and institutions.',
        href: '/services#framing',
        img: '/images/services/shipment-and-installation.webp',
      },
      {
        num: '03',
        title: 'Exhibition Design',
        description: 'Spatial planning and exhibition design that brings curatorial ideas to life in any setting.',
        href: '/services#consultancy',
        img: '/images/services/exhibition-design.jpg',
      },
      {
        num: '04',
        title: 'Art Curation',
        description: 'Strategic art consultancy and curatorial direction for collectors, corporate clients and cultural institutions.',
        href: '/services#consultancy',
        img: '/images/services/art-curation.jpg',
      },
    ].map((service, i) => (
      <a
        href={service.href}
        class="group flex items-center justify-between gap-8 px-8 md:px-12 py-8 border-t border-brand-border hover:bg-brand-border/30 transition-colors"
        data-fade
        style={`transition-delay: ${i * 60}ms`}
      >
        <div class="flex items-baseline gap-6 md:gap-10 min-w-0">
          <span class="text-brand-muted text-xs tracking-widest uppercase flex-shrink-0 w-6">{service.num}</span>
          <div class="min-w-0">
            <p class="font-display uppercase leading-none mb-2" style="font-size: clamp(1.5rem, 3.5vw, 3rem);">{service.title}</p>
            <p class="text-brand-muted text-sm leading-relaxed max-w-md hidden md:block">{service.description}</p>
          </div>
        </div>
        <div class="flex-shrink-0 w-28 h-20 md:w-40 md:h-28 overflow-hidden">
          <img
            src={service.img}
            alt={service.title}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            loading="lazy"
          />
        </div>
      </a>
    ))}
    <div class="px-8 md:px-12 py-8 border-t border-brand-border">
      <a href="/services" class="text-sm tracking-widest uppercase underline underline-offset-4 hover:opacity-50 transition-opacity">
        View all services
      </a>
    </div>
  </section>

  <!-- Selected Clients -->
  <section class="px-8 md:px-12 py-12 md:py-20 border-t border-brand-border">
    <p class="text-brand-muted text-xs tracking-widest uppercase mb-12">Selected Clients</p>
    <div class="grid grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-8 items-center">
      {[
        { src: '/images/logos/ceysson-benetiere.jpg', alt: 'Ceysson & Bénétière' },
        { src: '/images/logos/haneda.png', alt: 'Haneda Japan Airport Terminal' },
        { src: '/images/logos/soho-house.png', alt: 'Soho House' },
        { src: '/images/logos/mitsui-fudosan.png', alt: 'Mitsui Fudosan' },
        { src: '/images/logos/gallery-ether.png', alt: 'Gallery Ether' },
        { src: '/images/logos/bluebell.jpg', alt: 'Bluebell' },
        { src: '/images/logos/tokyo-american-club.webp', alt: 'Tokyo American Club' },
        { src: '/images/logos/isetan.svg', alt: 'Isetan' },
        { src: '/images/logos/courtyard-hiroo.png', alt: 'Courtyard Hiroo' },
        { src: '/images/logos/ultra-super-new.png', alt: 'Ultra Super New' },
        { src: '/images/logos/somsoc-gallery.png', alt: 'Somsoc Gallery' },
      ].map(({ src, alt }) => (
        <div class="flex items-center justify-center">
          <img src={src} alt={alt} class="w-24 h-8 object-contain mix-blend-multiply opacity-90 hover:opacity-100 transition-opacity duration-300" loading="lazy" />
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="px-8 md:px-12 py-16 md:py-28 border-t border-brand-border">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-10">
      <p class="font-display uppercase leading-none" style="font-size: clamp(2.5rem, 5vw, 6rem);">
        Ready to work<br />together?
      </p>
      <a
        href="/contact"
        class="inline-block bg-brand-text text-brand-bg px-10 py-4 text-sm tracking-widest uppercase hover:opacity-80 transition-opacity flex-shrink-0"
      >
        Get in Touch
      </a>
    </div>
  </section>
</Layout>
