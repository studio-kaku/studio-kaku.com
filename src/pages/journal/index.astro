---
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../data/projects.js';
const entries = projects.filter(p => p.journal);
---

<Layout title="Journal">
  <section class="px-8 md:px-12 pt-24 pb-16">
    <h1 class="font-display uppercase leading-none mb-6" style="font-size: clamp(2rem, 5vw, 5rem);" data-en="Journal" data-ja="ジャーナル">
      Journal
    </h1>
    <p class="text-brand-muted leading-relaxed max-w-lg" data-en="An ongoing record of our work in exhibitions and framing — the projects that keep evolving." data-ja="展覧会とフレーミングにおける私たちの仕事の継続的な記録です。常に進化し続けるプロジェクトたち。">
      An ongoing record of our work in exhibitions and framing — the projects that keep evolving.
    </p>
  </section>

  <section class="px-8 md:px-12 pb-20 border-t border-brand-border pt-10">
    <div class="grid grid-cols-2 md:grid-cols-3 gap-5 md:gap-7">
      {entries.map((entry, i) => (
        <a
          href={`/projects/${entry.slug}`}
          class="group"
          data-fade
          style={`transition-delay: ${(i % 3) * 80}ms`}
        >
          <div class="overflow-hidden aspect-[3/4] bg-brand-border mb-4">
            <img
              src={`/projects/${entry.slug}/${encodeURIComponent(entry.cover)}`}
              alt={entry.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              loading="lazy"
            />
          </div>
          <p class="text-xs text-brand-muted tracking-widest uppercase mb-1">{entry.year}</p>
          <p class="font-display uppercase leading-tight text-lg group-hover:opacity-50 transition-opacity">{entry.title}</p>
          {entry.tagline && (
            <p class="text-xs text-brand-muted mt-1">{entry.tagline}</p>
          )}
        </a>
      ))}
    </div>
  </section>
</Layout>
