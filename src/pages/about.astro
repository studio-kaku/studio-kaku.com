---
import Layout from '../layouts/Layout.astro';

const team = [
  {
    name: 'Yuki Kakuno',
    role: 'Framing, Installation & Art Care',
    bio: 'Born in Tsushima and educated in New York, Yuki has been based in Tokyo for over 10 years, specializing in high-quality framing for artists and galleries. His work includes projects with the Tokyo American Club and the flagship Ginza gallery of Ceysson & Bénétière. Guided by the belief in "framing that lets the artwork speak," he continues to bring out the full charm of each piece.',
    photo: '/images/team-yuki.png',
  },
  {
    name: 'Eleanor Ford',
    role: 'Art Consultancy, Creative Direction & Curation',
    bio: 'Born in France and raised between the UK and Hong Kong, Eleanor studied Spatial Design at the University of the Arts London before moving to Japan. She has spent the past eight years creating art projects that span government installations, private residences, galleries, and international art fairs — most recently leading large-scale work at Haneda Airport.',
    photo: '/images/team-eleanor.jpg',
  },
];
---

<Layout
  title="About"
  description="Studio Kaku is a collaboration between two experienced specialists in art framing, installation, consultancy and creative direction."
>
  <!-- Logo hero -->
  <section class="px-8 md:px-12 pt-20 pb-4 flex justify-center">
    <img src="/logo.svg" alt="Studio Kaku" class="w-full max-w-lg" />
  </section>

  <!-- Page header -->
  <section class="px-8 md:px-12 pt-8 pb-16">
    <p class="text-brand-muted text-xs tracking-widest uppercase mb-8">Who we are</p>
    <h1 class="font-display uppercase leading-none" style="font-size: clamp(3rem, 9vw, 11rem);">About Studio Kaku</h1>
  </section>

  <!-- Mission -->
  <section class="px-8 md:px-12 py-24 border-t border-brand-border">
    <div class="max-w-3xl">
      <p class="font-serif leading-snug mb-10" style="font-size: clamp(1.75rem, 3vw, 3rem);">
        Studio Kaku was founded on the belief that art deserves both the
        right frame and the right context.
      </p>
      <p class="text-brand-muted leading-relaxed mb-5 text-lg">
        We are a collaboration between two specialists — one rooted in the
        material and physical world of framing, installation and conservation;
        the other in the intellectual and cultural work of consultancy,
        direction and curation. Together, we offer a complete picture.
      </p>
      <p class="text-brand-muted leading-relaxed text-lg">
        Our practice is built on close relationships: with artists, framers,
        collectors, institutions and the works themselves. We take time to
        understand what each project needs, and we bring craft and care to
        every stage of the process.
      </p>
    </div>
  </section>

  <!-- Team -->
  <section class="px-8 md:px-12 py-24 border-t border-brand-border">
    <h2 class="font-display uppercase leading-none mb-20" style="font-size: clamp(2.5rem, 5vw, 6rem);">The Team</h2>
    <div class="grid md:grid-cols-2 gap-20">
      {team.map((member) => (
        <div>
          <div class="w-full aspect-[3/4] overflow-hidden mb-8">
            <img src={member.photo} alt={member.name} class="w-full h-full object-cover object-top" />
          </div>
          <h3 class="font-serif text-2xl mb-2">{member.name}</h3>
          <p class="text-brand-accent text-sm tracking-widest uppercase mb-6">{member.role}</p>
          <p class="text-brand-muted leading-relaxed">{member.bio}</p>
        </div>
      ))}
    </div>
  </section>
</Layout>
