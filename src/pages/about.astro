---
import Layout from '../layouts/Layout.astro';

const team = [
  {
    name: 'Yuki Kakuno',
    role: 'Framing, Installation & Art Care',
    roleJa: 'フレーミング、設置とアートケア',
    bio: 'Born in Tsushima and educated in New York, Yuki has been based in Tokyo for over 10 years, specializing in high-quality framing for artists and galleries. His work includes projects with the Tokyo American Club and the flagship Ginza gallery of Ceysson & Bénétière. Guided by the belief in "framing that lets the artwork speak," he continues to bring out the full charm of each piece.',
    bioJa: '対馬生まれ、ニューヨーク育ちのYukiは、東京を拠点に10年以上、アーティストやギャラリーのための高品質なフレーミングを専門にしてきました。東京アメリカンクラブや銀座のCeysson & Bénétièreフラッグシップギャラリーなどのプロジェクトにも携わっています。「作品が語るフレーミング」の信念のもと、一点一点の魅力を最大限に引き出しています。',
    photo: '/images/team-yuki.png',
    link: { label: 'jukaframing.com', href: 'http://jukaframing.com' },
  },
  {
    name: 'Eleanor Ford',
    role: 'Art Consultancy, Creative Direction & Curation',
    roleJa: 'アートコンサルタンシー、クリエイティブディレクション＆キュレーション',
    bio: 'Born in France and raised between the UK and Hong Kong, Eleanor studied Spatial Design at the University of the Arts London before moving to Japan. She has spent the past eight years creating art projects that span government installations, private residences, galleries, and international art fairs — most recently leading large-scale work at Haneda Airport.',
    bioJa: 'フランス生まれ、イギリスと香港で育ったEleanorは、University of the Arts LondonでSpatial Designを学んだ後、日本へ移住。この8年間、政府施設、個人邸宅、ギャラリー、国際アートフェアにまたがるアートプロジェクトを手がけ、直近では羽田空港での大規模プロジェクトをリードしました。',
    photo: '/images/team-eleanor.jpg',
    link: null,
  },
];
---

<Layout
  title="About"
  description="Studio Kaku is a collaboration between two experienced specialists in art framing, installation, consultancy and creative direction."
>
  <!-- Page header -->
  <section class="px-8 md:px-12 pt-14 md:pt-20 pb-10 md:pb-16">
    <p class="text-brand-muted text-xs tracking-widest uppercase mb-8" data-en="Who we are" data-ja="私たちについて">Who we are</p>
    <h1 class="font-display uppercase leading-none" style="font-size: clamp(2rem, 5vw, 5rem);" data-en="About Studio Kaku" data-ja="Studio Kakuについて">About Studio Kaku</h1>
  </section>

  <!-- Mission -->
  <section class="px-8 md:px-12 py-14 md:py-24 border-t border-brand-border">
    <div class="max-w-3xl">
      <p class="font-serif leading-snug mb-8 text-xl md:text-2xl" data-en="Studio Kaku was founded on the belief that art deserves both the right frame and the right context." data-ja="Studio Kakuは、アートには適切な額装と適切なコンテクストが必要であるという信念のもとに設立されました。">
        Studio Kaku was founded on the belief that art deserves both the
        right frame and the right context.
      </p>
      <p class="text-brand-muted leading-relaxed mb-5" data-en="We are a collaboration between two specialists — one rooted in the material and physical world of framing, installation and conservation; the other in the intellectual and cultural work of consultancy, direction and curation. Together, we offer a complete picture." data-ja="私たちは二人の専門家のコラボレーションです。一方はフレーミング・設置・保存という物質的・物理的世界を、もう一方はコンサルタンシー・ディレクション・キュレーションという知的・文化的な仕事を担っています。二人合わせれば、完全な絵が描けます。">
        We are a collaboration between two specialists — one rooted in the
        material and physical world of framing, installation and conservation;
        the other in the intellectual and cultural work of consultancy,
        direction and curation. Together, we offer a complete picture.
      </p>
      <p class="text-brand-muted leading-relaxed" data-en="Our practice is built on close relationships: with artists, framers, collectors, institutions and the works themselves. We take time to understand what each project needs, and we bring craft and care to every stage of the process." data-ja="私たちの実践は、アーティスト、額装師、コレクター、機関、そして作品そのものとの密接な関係によって築かれています。各プロジェクトのニーズを深く理解し、プロセスのすべての段階に職人技と誠意を持って取り組みます。">
        Our practice is built on close relationships: with artists, framers,
        collectors, institutions and the works themselves. We take time to
        understand what each project needs, and we bring craft and care to
        every stage of the process.
      </p>
    </div>
  </section>

  <!-- Team -->
  <section class="px-8 md:px-12 py-14 md:py-24 border-t border-brand-border">
    <h2 class="font-display uppercase leading-none mb-10 md:mb-20" style="font-size: clamp(2.5rem, 5vw, 6rem);" data-en="The Team" data-ja="チーム">The Team</h2>
    <div class="grid md:grid-cols-2 gap-14 md:gap-20">
      {team.map((member) => (
        <div>
          <div class="w-full aspect-[3/4] overflow-hidden mb-6">
            <img src={member.photo} alt={member.name} class="w-full h-full object-cover object-top" />
          </div>
          <h3 class="font-serif text-xl mb-1">{member.name}</h3>
          <p class="text-brand-accent text-xs tracking-widest uppercase mb-4" data-en={member.role} data-ja={member.roleJa}>{member.role}</p>
          <p class="text-brand-muted leading-relaxed text-sm" data-en={member.bio} data-ja={member.bioJa}>{member.bio}</p>
          {member.link && (
            <a href={member.link.href} target="_blank" rel="noopener noreferrer" class="inline-block mt-4 text-xs tracking-widest uppercase underline underline-offset-4 hover:opacity-50 transition-opacity">
              {member.link.label}
            </a>
          )}
        </div>
      ))}
    </div>
  </section>
</Layout>
