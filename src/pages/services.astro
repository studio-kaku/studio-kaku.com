---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    num: '01',
    title: { en: 'Art Advice', ja: 'アートアドバイス' },
    desc: {
      en: 'Visit the property to advise on what type of art would fit and stand out in each area. Relationship building with clients so as to understand aspirations, likes, dislikes, and their taste.',
      ja: '物件を訪問し、空間に合った印象的なアートを提案。対話を重ね、クライアントとの信頼関係を築きます。',
    },
    img: '/images/services/art-curation.jpg',
    href: '#consultancy',
  },
  {
    num: '02',
    title: { en: 'Art Curation', ja: 'アートキュレーション' },
    desc: {
      en: "Provide an array of ideas on how the art could be displayed, making the most of the space's character, light, scale and surroundings.",
      ja: '空間の特徴を活かしつつ、光の入り方や色味、広さ、周囲の環境に合わせて、アートの魅力を最大限に引き出す展示アイデアを多角的にご提案します。',
    },
    img: '/images/services/art-curation.jpg',
    href: '#consultancy',
  },
  {
    num: '03',
    title: { en: 'Negotiating & Commissioning', ja: '交渉とコミッション' },
    desc: {
      en: 'Work with artists to create the perfect piece for the project, negotiate price, timeline and deliverables.',
      ja: 'プロジェクトに最適な作品を制作するため、アーティストと連携して進めます。価格や納期、納品内容についても調整・交渉を行います。',
    },
    img: '/images/services/exhibition-design.jpg',
    href: '#consultancy',
  },
  {
    num: '04',
    title: { en: 'Framing', ja: 'フレーミング' },
    desc: {
      en: 'Source custom-made framing to enhance the beauty of the artwork, reviewing the different materials for all different sizes and types of artwork. Framing by Juka Framing.',
      ja: 'アートワークの美しさを引き立てるオーダーメイドの額縁を提供します。さまざまなサイズやタイプの作品に最適な素材を検討します。',
    },
    img: '/images/services/framing.jpg',
    href: '#framing',
    link: { label: 'jukaframing.com', href: 'http://jukaframing.com' },
  },
  {
    num: '05',
    title: { en: 'Shipment & Installation', ja: '輸送と設置' },
    desc: {
      en: 'Provide best-market shipment service door to door, and service the installation so the client has nothing to worry about.',
      ja: '最高水準の宅配と設置サポートで、クライアントが安心して任せられる体制を提供します。',
    },
    img: '/images/services/shipment-and-installation.webp',
    href: '#framing',
  },
  {
    num: '06',
    title: { en: 'Exhibition Design', ja: '展示デザイン' },
    desc: {
      en: 'Larger scale installation support: develop advanced plans, timelines, concepts and exhibition price lists to assist organisations.',
      ja: '大規模なインスタレーションに対応し、企画立案、スケジュール管理、コンセプト設計、展示価格リスト作成などを通じて、プロジェクトの推進をサポートします。',
    },
    img: '/images/services/exhibition-design.jpg',
    href: '#consultancy',
  },
];
---

<Layout
  title="Services"
  description="Studio Kaku offers art consultancy, creative direction, curation, bespoke framing and installation."
>
  <!-- Page header -->
  <section class="px-8 md:px-12 pt-14 md:pt-20 pb-10 md:pb-16">
    <p class="text-brand-muted text-xs tracking-widest uppercase mb-8" data-fade-text data-en="What we do" data-ja="サービス内容">What we do</p>
    <h1 class="font-display uppercase leading-none" style="font-size: clamp(3rem, 9vw, 11rem);" data-fade-text data-en="Services" data-ja="サービス">Services</h1>
  </section>

  <!-- Services list -->
  <section class="border-t border-brand-border">
    {services.map((item, i) => (
      <a
        href={item.href}
        class="group flex items-center justify-between gap-8 px-8 md:px-12 py-8 border-b border-brand-border hover:bg-brand-border/30 transition-colors"
        data-fade
        style={`transition-delay: ${i * 60}ms`}
      >
        <div class="flex items-baseline gap-6 md:gap-10 min-w-0">
          <span class="text-brand-muted text-xs tracking-widest uppercase flex-shrink-0 w-6">{item.num}</span>
          <div class="min-w-0">
            <p class="font-display uppercase leading-none mb-2" style="font-size: clamp(1.5rem, 3.5vw, 3rem);" data-en={item.title.en} data-ja={item.title.ja}>{item.title.en}</p>
            <p class="text-brand-muted text-sm leading-relaxed max-w-md hidden md:block" data-en={item.desc.en} data-ja={item.desc.ja}>{item.desc.en}</p>
          {item.link && (
            <a href={item.link.href} target="_blank" rel="noopener noreferrer" onclick="event.stopPropagation()" class="hidden md:inline-block mt-2 text-xs tracking-widest uppercase underline underline-offset-4 hover:opacity-50 transition-opacity">
              {item.link.label}
            </a>
          )}
          </div>
        </div>
        <div class="flex-shrink-0 w-28 h-20 md:w-40 md:h-28 overflow-hidden">
          <img
            src={item.img}
            alt={item.title.en}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            loading="lazy"
          />
        </div>
      </a>
    ))}
  </section>

  <!-- CTA -->
  <section class="px-8 md:px-12 py-16 md:py-28 border-t border-brand-border">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-10" data-fade-text>
      <p class="font-display uppercase leading-none" style="font-size: clamp(2.5rem, 5vw, 6rem);" data-en="Ready to work together?" data-ja="一緒に取り組みませんか？">
        Ready to work<br />together?
      </p>
      <a
        href="/contact"
        class="inline-block bg-brand-text text-brand-bg px-10 py-4 text-sm tracking-widest uppercase hover:opacity-80 transition-opacity flex-shrink-0"
        data-en="Get in Touch"
        data-ja="お問い合わせ"
      >
        Get in Touch
      </a>
    </div>
  </section>
</Layout>
