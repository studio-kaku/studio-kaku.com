---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Services"
  description="Studio Kaku offers expert framing, installation, art care, consultancy, creative direction and curation."
>
  <!-- Page header -->
  <section class="px-8 md:px-12 pt-20 pb-16">
    <p class="text-brand-muted text-xs tracking-widest uppercase mb-8">What we do</p>
    <h1 class="font-serif leading-none" style="font-size: clamp(3rem, 7vw, 9rem);">Services</h1>
  </section>

  <!-- Service 1: Framing, Installation & Art Care -->
  <section id="framing" class="px-8 md:px-12 py-24 border-t border-brand-border">
    <div class="grid md:grid-cols-2 gap-20 items-start">
      <div>
        <p class="text-brand-muted text-xs tracking-widest uppercase mb-8">01</p>
        <h2 class="font-serif leading-tight mb-10" style="font-size: clamp(2rem, 4vw, 4rem);">
          Framing, Installation<br />&amp; Art Care
        </h2>
        <div class="space-y-5 text-brand-muted leading-relaxed">
          <p>
            A great frame does more than protect — it activates a work. We
            source, design and produce bespoke frames in dialogue with the art
            itself, working with conservation-grade materials and trusted
            specialist craftspeople.
          </p>
          <p>
            Our installation service covers everything from a single piece in a
            private home to large-scale hanging programmes for galleries and
            institutional collections.
          </p>
          <p>
            We also advise on the long-term care of works on paper, canvas and
            other media: storage, lighting, environmental conditions and
            handling — so your collection remains in peak condition.
          </p>
        </div>

        <ul class="mt-12 space-y-3 text-sm">
          {[
            'Bespoke frame design & production',
            'Conservation framing & glazing',
            'Professional art installation',
            'Collection storage advice',
            'Lighting consultation',
            'Art care & condition reporting',
          ].map((item) => (
            <li class="flex items-start gap-4">
              <span class="mt-2 w-1 h-1 rounded-full bg-brand-accent flex-shrink-0"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <div class="space-y-2">
        <div class="overflow-hidden">
          <img
            src="/images/framing-example.jpg"
            alt="Bespoke framed artwork"
            class="w-full aspect-square object-cover hover:scale-105 transition-transform duration-700"
          />
        </div>
        <div class="overflow-hidden">
          <img
            src="/images/installation-gallery.jpg"
            alt="Professional art installation"
            class="w-full aspect-video object-cover hover:scale-105 transition-transform duration-700"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Service 2: Art Consultancy & Creative Direction -->
  <section id="consultancy" class="px-8 md:px-12 py-24 border-t border-brand-border">
    <div class="grid md:grid-cols-2 gap-20 items-start">
      <div class="order-2 md:order-1 space-y-2">
        <div class="overflow-hidden">
          <img
            src="/images/exhibition-space.jpg"
            alt="Gallery exhibition space"
            class="w-full aspect-square object-cover hover:scale-105 transition-transform duration-700"
          />
        </div>
        <div class="overflow-hidden">
          <img
            src="/images/curation-visitors.jpg"
            alt="Visitors experiencing curated exhibition"
            class="w-full aspect-video object-cover hover:scale-105 transition-transform duration-700"
          />
        </div>
      </div>

      <div class="order-1 md:order-2">
        <p class="text-brand-muted text-xs tracking-widest uppercase mb-8">02</p>
        <h2 class="font-serif leading-tight mb-10" style="font-size: clamp(2rem, 4vw, 4rem);">
          Art Consultancy, Creative<br />Direction &amp; Curation
        </h2>
        <div class="space-y-5 text-brand-muted leading-relaxed">
          <p>
            We work with private collectors, developers, hospitality brands and
            organisations to build coherent, meaningful art programmes —
            whether acquiring a first work or shaping an entire collection
            strategy.
          </p>
          <p>
            Our creative direction brings a strong curatorial perspective to
            spaces and projects: developing narratives, identifying artists and
            creating environments where art and context resonate together.
          </p>
          <p>
            From artist commissions and exhibition development to brand
            partnerships, we bring taste, rigour and practical experience to
            every engagement.
          </p>
        </div>

        <ul class="mt-12 space-y-3 text-sm">
          {[
            'Art acquisition & collection strategy',
            'Artist sourcing & commissions',
            'Exhibition development & curation',
            'Spatial creative direction',
            'Corporate art programmes',
            'Brand & cultural partnerships',
          ].map((item) => (
            <li class="flex items-start gap-4">
              <span class="mt-2 w-1 h-1 rounded-full bg-brand-accent flex-shrink-0"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="px-8 md:px-12 py-28 border-t border-brand-border">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-10">
      <p class="font-serif leading-none" style="font-size: clamp(2.5rem, 5vw, 6rem);">
        Ready to work<br />together?
      </p>
      <a
        href="/contact"
        class="inline-block bg-brand-text text-brand-bg px-10 py-4 text-sm tracking-widest uppercase hover:opacity-80 transition-opacity flex-shrink-0"
      >
        Get in Touch
      </a>
    </div>
  </section>
</Layout>
