---
import Layout from '../layouts/Layout.astro';

const consultancyServices = [
  {
    title: 'Art Advice',
    desc: 'Visit the space to understand its character, then advise on what art would fit, stand out and start a conversation in each area.',
  },
  {
    title: 'Art Curation',
    desc: 'Build a coherent programme — selecting artists, developing a narrative and making the most of what the space has to offer.',
  },
  {
    title: 'Artist Commissions',
    desc: 'Introduce the right artist for a project and manage the commission from concept to delivery.',
  },
  {
    title: 'Negotiating & Acquiring',
    desc: 'Work directly with galleries, artists and auction houses to agree on price, timeline and terms.',
  },
  {
    title: 'Creative Direction',
    desc: 'Shape the visual and conceptual identity of a project — from brand partnerships to hospitality and cultural institutions.',
  },
  {
    title: 'Exhibition Development',
    desc: 'Develop shows from scratch: concept, artist liaison, floor plans, timelines and on-site management.',
  },
];

const framingServices = [
  {
    title: 'Bespoke Framing',
    desc: 'Design and produce frames in dialogue with the artwork — reviewing materials, mouldings and mounts for all sizes and media.',
  },
  {
    title: 'Shipment & Installation',
    desc: 'Best-in-market door-to-door shipping with full installation, so clients have nothing to worry about.',
  },
  {
    title: 'Exhibition Design & Hang',
    desc: 'Larger-scale hanging programmes for galleries and institutions — advanced plans, timelines, concepts and on-site execution.',
  },
  {
    title: 'Art Care & Advice',
    desc: 'Guidance on storage, lighting, environmental conditions and handling so collections stay in peak condition for generations.',
  },
];
---

<Layout
  title="Services"
  description="Studio Kaku offers art consultancy, creative direction, curation, bespoke framing and installation."
>
  <!-- Page header -->
  <section class="px-8 md:px-12 pt-20 pb-16">
    <p class="text-brand-muted text-xs tracking-widest uppercase mb-8" data-fade-text>What we do</p>
    <h1 class="font-display uppercase leading-none" style="font-size: clamp(3rem, 9vw, 11rem);" data-fade-text style="transition-delay:60ms">Services</h1>
  </section>

  <!-- Service 01: Art Consultancy -->
  <section id="consultancy" class="border-t border-brand-border">
    <!-- Service title row -->
    <div class="px-8 md:px-12 py-16 md:flex md:items-end md:justify-between gap-20" data-fade-text>
      <div class="flex items-start gap-6 md:gap-10">
        <span class="text-brand-muted text-xs tracking-widest uppercase mt-1 flex-shrink-0">01</span>
        <h2 class="font-display uppercase leading-none" style="font-size: clamp(2rem, 5vw, 6rem);">
          Art Consultancy,<br />Creative Direction<br />&amp; Curation
        </h2>
      </div>
      <p class="text-brand-muted leading-relaxed max-w-sm mt-8 md:mt-0 flex-shrink-0">
        We work with private collectors, developers, hospitality brands and
        organisations to build coherent, meaningful art programmes — whether
        acquiring a first work or shaping an entire collection strategy.
      </p>
    </div>

    <!-- Services grid -->
    <div class="border-t border-brand-border grid md:grid-cols-2 lg:grid-cols-3">
      {consultancyServices.map((item, i) => (
        <div
          class="px-8 md:px-10 py-10 border-b border-brand-border md:border-r"
          data-fade
          style={`transition-delay: ${(i % 3) * 80}ms`}
        >
          <p class="text-brand-muted text-xs tracking-widest uppercase mb-4">{String(i + 1).padStart(2, '0')}</p>
          <p class="font-medium text-brand-text mb-3">{item.title}</p>
          <p class="text-brand-muted text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>

    <!-- Consultancy image strip -->
    <div class="grid grid-cols-3 border-b border-brand-border" data-fade>
      <div class="overflow-hidden aspect-[4/3] col-span-2">
        <img
          src="/projects/wandler/Front main image.jpg"
          alt="Creative direction — Wandler"
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
          loading="lazy"
        />
      </div>
      <div class="overflow-hidden aspect-[4/3]">
        <img
          src="/projects/arthur-harmonyst/Front main image.JPG"
          alt="Exhibition — POLYGON1993"
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- Service 02: Framing & Installation -->
  <section id="framing" class="border-t border-brand-border">
    <!-- Service title row -->
    <div class="px-8 md:px-12 py-16 md:flex md:items-end md:justify-between gap-20" data-fade-text>
      <div class="flex items-start gap-6 md:gap-10">
        <span class="text-brand-muted text-xs tracking-widest uppercase mt-1 flex-shrink-0">02</span>
        <h2 class="font-display uppercase leading-none" style="font-size: clamp(2rem, 5vw, 6rem);">
          Framing,<br />Installation<br />&amp; Art Care
        </h2>
      </div>
      <p class="text-brand-muted leading-relaxed max-w-sm mt-8 md:mt-0 flex-shrink-0">
        A great frame does more than protect — it activates a work. We source,
        design and produce bespoke frames in dialogue with the art itself,
        working with conservation-grade materials and trusted craftspeople.
      </p>
    </div>

    <!-- Services grid -->
    <div class="border-t border-brand-border grid md:grid-cols-2 lg:grid-cols-4">
      {framingServices.map((item, i) => (
        <div
          class="px-8 md:px-10 py-10 border-b border-brand-border md:border-r"
          data-fade
          style={`transition-delay: ${(i % 4) * 80}ms`}
        >
          <p class="text-brand-muted text-xs tracking-widest uppercase mb-4">{String(i + 1).padStart(2, '0')}</p>
          <p class="font-medium text-brand-text mb-3">{item.title}</p>
          <p class="text-brand-muted text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>

    <!-- Framing image strip -->
    <div class="grid grid-cols-3 border-b border-brand-border" data-fade>
      <div class="overflow-hidden aspect-[4/3]">
        <img
          src="/projects/ceysson-benetiere/Front main image.jpg"
          alt="Framing — Ceysson & Bénétière"
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
          loading="lazy"
        />
      </div>
      <div class="overflow-hidden aspect-[4/3] col-span-2">
        <img
          src="/projects/framing/Front main image.jpg"
          alt="Bespoke framing"
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="px-8 md:px-12 py-28 border-t border-brand-border">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-10" data-fade-text>
      <p class="font-display uppercase leading-none" style="font-size: clamp(2.5rem, 5vw, 6rem);">
        Ready to work<br />together?
      </p>
      <a
        href="/contact"
        class="inline-block bg-brand-text text-brand-bg px-10 py-4 text-sm tracking-widest uppercase hover:opacity-80 transition-opacity flex-shrink-0"
      >
        Get in Touch
      </a>
    </div>
  </section>
</Layout>
