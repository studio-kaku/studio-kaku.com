---
const nav = [
  { label: 'Services', href: '/services' },
  { label: 'Projects', href: '/projects' },
  { label: 'Journal', href: '/journal' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-brand-border">
  <div class="px-8 md:px-12 py-6 flex items-center justify-between">
    <a href="/" class="hover:opacity-70 transition-opacity">
      <img src="/logo.png" alt="Studio Kaku" class="h-14 w-auto" />
    </a>
    <nav class="flex items-center gap-10">
      {nav.map(({ label, href }) => (
        <a
          href={href}
          class={`text-sm tracking-wide transition-opacity hover:opacity-70 ${
            currentPath.startsWith(href) ? 'opacity-100 font-medium' : 'opacity-60'
          }`}
        >
          {label.toUpperCase()}
        </a>
      ))}
    </nav>
  </div>
</header>
