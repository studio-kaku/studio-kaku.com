---
interface Props {
  activeSection?: string;
}

const { activeSection } = Astro.props;

const nav = [
  { label: 'Journal', ja: 'ジャーナル', href: '/journal' },
  { label: 'Projects', ja: 'プロジェクト', href: '/projects' },
  { label: 'Services', ja: 'サービス', href: '/services' },
  { label: 'About Us', ja: 'About Us', href: '/about' },
  { label: 'Contact', ja: 'お問い合わせ', href: '/contact' },
];

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (activeSection) return activeSection === href.replace('/', '');
  return currentPath.startsWith(href);
}
---

<header class="border-b border-brand-border">
  <div id="proposal-bar" class="hidden px-8 md:px-12 py-2 border-b border-brand-border bg-brand-bg flex items-center">
    <a id="proposal-back-link" href="#" class="text-[10px] tracking-[0.2em] uppercase text-brand-accent hover:opacity-70 transition-opacity flex items-center gap-2">
      <span>←</span><span id="proposal-back-label">Back to proposal</span>
    </a>
  </div>
  <div class="px-8 md:px-12 py-6 flex items-center justify-between">
    <a href="/" class="hover:opacity-70 transition-opacity">
      <img src="/studio-kaku-logo.png" alt="Studio Kaku" class="h-24 md:h-32 w-auto" />
    </a>
    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-10">
      {nav.map(({ label, ja, href }) => (
        <a
          href={href}
          data-en={label.toUpperCase()}
          data-ja={ja.toUpperCase()}
          class={`text-sm tracking-wide transition-opacity hover:opacity-70 ${
            isActive(href) ? 'opacity-100 font-medium' : 'opacity-60'
          }`}
        >
          {label.toUpperCase()}
        </a>
      ))}
    </nav>
    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden flex flex-col gap-1.5 p-2 -mr-2"
      aria-label="Open menu"
      aria-expanded="false"
    >
      <span class="block w-6 h-px bg-brand-text transition-all duration-300" id="bar1"></span>
      <span class="block w-6 h-px bg-brand-text transition-all duration-300" id="bar2"></span>
      <span class="block w-6 h-px bg-brand-text transition-all duration-300" id="bar3"></span>
    </button>
  </div>
  <!-- Mobile nav panel -->
  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-brand-border bg-brand-bg"
  >
    <nav class="px-8 py-8 flex flex-col gap-6">
      {nav.map(({ label, ja, href }) => (
        <a
          href={href}
          data-en={label.toUpperCase()}
          data-ja={ja.toUpperCase()}
          class={`text-base tracking-widest transition-opacity hover:opacity-70 ${
            isActive(href) ? 'opacity-100 font-medium' : 'opacity-60'
          }`}
        >
          {label.toUpperCase()}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  // Proposal back link logic
  const path = window.location.pathname.replace(/\/$/, '') || '/';
  if (path === '/resort' || path === '/villa') {
    sessionStorage.setItem('proposalUrl', '/resort/');
    sessionStorage.setItem('proposalLabel', 'Back to resort proposal');
  } else {
    const storedUrl = sessionStorage.getItem('proposalUrl');
    const storedLabel = sessionStorage.getItem('proposalLabel');
    if (storedUrl && storedLabel) {
      const bar = document.getElementById('proposal-bar') as HTMLDivElement;
      const link = document.getElementById('proposal-back-link') as HTMLAnchorElement;
      const labelEl = document.getElementById('proposal-back-label') as HTMLSpanElement;
      bar.classList.remove('hidden');
      link.href = storedUrl;
      labelEl.textContent = storedLabel;
    }
  }

  const btn = document.getElementById('mobile-menu-btn') as HTMLButtonElement;
  const menu = document.getElementById('mobile-menu') as HTMLDivElement;
  const bar1 = document.getElementById('bar1') as HTMLSpanElement;
  const bar2 = document.getElementById('bar2') as HTMLSpanElement;
  const bar3 = document.getElementById('bar3') as HTMLSpanElement;

  btn?.addEventListener('click', () => {
    const isOpen = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!isOpen));
    menu.classList.toggle('hidden');
    if (!isOpen) {
      bar1.style.transform = 'translateY(7px) rotate(45deg)';
      bar2.style.opacity = '0';
      bar3.style.transform = 'translateY(-7px) rotate(-45deg)';
    } else {
      bar1.style.transform = '';
      bar2.style.opacity = '';
      bar3.style.transform = '';
    }
  });
</script>
