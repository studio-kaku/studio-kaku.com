# ── Slack ──────────────────────────────────────────────────────────────────
# From https://api.slack.com/apps → your app → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-...

# From https://api.slack.com/apps → your app → Basic Information → App-Level Tokens
SLACK_APP_TOKEN=xapp-...

# The channel ID where the bot listens (right-click channel → Copy link → last segment)
SLACK_CHANNEL_ID=C...

# ── GitHub ─────────────────────────────────────────────────────────────────
# Personal access token with repo + workflow permissions
GITHUB_TOKEN=ghp_...

# owner/repo  e.g. studio-kaku/studio-kaku.com
GITHUB_REPO=your-org/studio-kaku.com

# Absolute path to the local clone of the repo (checked out on the staging branch)
REPO_DIR=/path/to/studio-kaku.com

# ── Access control ─────────────────────────────────────────────────────────
# Comma-separated Slack user IDs allowed to run /approve
# Find your ID: Slack → profile → ··· → Copy member ID
APPROVED_USER_IDS=U...,U...

# ── Optional ───────────────────────────────────────────────────────────────
STAGING_URL=https://staging.studio-kaku.com
CLAUDE_MODEL=sonnet
